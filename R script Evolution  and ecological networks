tree_bd_high    <- rlineage(b = 1.0, d = 0.7, Tmax = 3)   # high extinction

# Compute tree balance (Colless index) and diversity
get_stats <- function(tree, label) {
  ntips <- length(tree$tip.label)
  data.frame(model = label, n_tips = ntips)
}

stats <- rbind(
  get_stats(tree_pure_birth, "Pure Birth (d=0)"),
  get_stats(tree_bd_low,     "Birth-Death (d=0.3)"),
  get_stats(tree_bd_high,    "Birth-Death (d=0.7)")
)
