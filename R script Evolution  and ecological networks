# TASK 2: Simulate Trait Evolution — Brownian Motion vs OU
# ============================================================
# Goal: Simulate a continuous trait along a phylogeny under
# BM (random drift) and OU (stabilizing selection) and
# compare the resulting trait distributions.
# ============================================================

cat("\n=== TASK 2: BM vs OU Trait Evolution ===\n")

# Build a balanced reference tree (50 tips)
tree50 <- pbtree(n = 50, scale = 1)

# BM simulation: sigma^2 = rate of variance accumulation
trait_BM <- fastBM(tree50, sig2 = 0.5, internal = FALSE)

# OU simulation: alpha = strength of pull toward optimum theta
trait_OU <- fastBM(tree50, sig2 = 0.5, a = 0,   # starting value
                   internal = FALSE,
                   # OU via phytools:
                   alpha = 3)   # strong pull → low variance

cat("BM trait variance:", round(var(trait_BM), 3), "\n")
cat("OU trait variance:", round(var(trait_OU), 3), "\n")

# --- Plot: side-by-side trait distributions ---
df_traits <- data.frame(
  trait = c(trait_BM, trait_OU),
  model = rep(c("Brownian Motion", "Ornstein-Uhlenbeck"), each = 50)
)

p_density <- ggplot(df_traits, aes(x = trait, fill = model, color = model)) +
  geom_density(alpha = 0.45, size = 1) +
  geom_rug(aes(color = model), alpha = 0.6, length = unit(0.03, "npc")) +
  scale_fill_manual(values  = c("#2E86AB", "#E84855")) +
  scale_color_manual(values = c("#2E86AB", "#E84855")) +
  labs(title = "TASK 2 — Trait Distributions: BM vs OU",
       subtitle = paste0("BM variance = ", round(var(trait_BM), 3),
                         "   |   OU variance = ", round(var(trait_OU), 3)),
       x = "Trait Value", y = "Density", fill = "Model", color = "Model") +
