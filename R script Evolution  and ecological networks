# ============================================================
# TASK 3: Visualize BM vs OU Variance Through Time
# ============================================================
# Goal: Show how trait variance accumulates differently under
# BM (linear) vs OU (saturating) as a function of time.
# ============================================================

cat("\n=== TASK 3: Variance Through Time ===\n")

n_sims  <- 200
n_steps <- 100
time    <- seq(0, 5, length.out = n_steps)
sigma2  <- 0.3
alpha   <- 1.5
theta   <- 0

# Analytical expectations
var_BM <- sigma2 * time                                         # linear
var_OU <- (sigma2 / (2 * alpha)) * (1 - exp(-2 * alpha * time)) # saturating

df_var <- data.frame(
  time     = rep(time, 2),
  variance = c(var_BM, var_OU),
  model    = rep(c("Brownian Motion", "Ornstein-Uhlenbeck"), each = n_steps)
)

# Simulate individual trajectories for context
sim_trajectories <- function(model = "BM", n = 30, steps = 100,
                             sig2 = 0.3, alp = 1.5, th = 0) {
  dt <- 5 / steps
  traj <- matrix(0, nrow = steps, ncol = n)
  for (i in 2:steps) {
    if (model == "BM") {
      traj[i, ] <- traj[i-1, ] + rnorm(n, 0, sqrt(sig2 * dt))
    } else {
      traj[i, ] <- traj[i-1, ] +
        alp * (th - traj[i-1, ]) * dt + rnorm(n, 0, sqrt(sig2 * dt))
    }
  }
  df <- as.data.frame(traj)
  df$time <- seq(0, 5, length.out = steps)
  tidyr::pivot_longer(df, -time, names_to = "sim", values_to = "trait")
}

# Use base R pivot if tidyr not available
pivot_manual <- function(mat, model_name) {
  dt  <- 5 / nrow(mat)
  t_vec <- seq(0, 5, length.out = nrow(mat))
  do.call(rbind, lapply(1:ncol(mat), function(j)
    data.frame(time = t_vec, trait = mat[, j],
               sim = paste0("s", j), model = model_name)))
}

steps <- 100; n_t <- 40; dt <- 5 / steps
mat_BM <- matrix(0, steps, n_t)
mat_OU <- matrix(0, steps, n_t)
for (i in 2:steps) {
  mat_BM[i, ] <- mat_BM[i-1, ] + rnorm(n_t, 0, sqrt(sigma2 * dt))
  mat_OU[i, ] <- mat_OU[i-1, ] +
    alpha * (theta - mat_OU[i-1, ]) * dt + rnorm(n_t, 0, sqrt(sigma2 * dt))
}
df_traj <- rbind(pivot_manual(mat_BM, "Brownian Motion"),
                 pivot_manual(mat_OU, "Ornstein-Uhlenbeck"))

p_traj <- ggplot(df_traj, aes(x = time, y = trait,
                              group = interaction(sim, model),
                              color = model)) +
  geom_line(alpha = 0.15, size = 0.4) +
  geom_line(data = df_var, aes(x = time, y = sqrt(variance),
                               color = model, group = model),
            size = 2, linetype = "dashed", inherit.aes = FALSE) +
  scale_color_manual(values = c("#2E86AB", "#E84855")) +
  facet_wrap(~model) +
  labs(title = "TASK 3 — Trait Trajectories & Variance Through Time",
       subtitle = "Dashed lines = analytical SD; thin lines = individual simulations",
       x = "Time", y = "Trait Value", color = "Model") +
  theme_minimal(base_size = 13) +
  theme(plot.title = element_text(face = "bold"),
        legend.position = "none")

p_variance <- ggplot(df_var, aes(x = time, y = variance,
                                 color = model, linetype = model)) +
  geom_line(size = 1.8) +
  scale_color_manual(values = c("#2E86AB", "#E84855")) +
  labs(title = "Expected Trait Variance",
       x = "Time", y = "Variance σ²(t)",
       color = "Model", linetype = "Model") +
  theme_minimal(base_size = 13) +
  theme(plot.title = element_text(face = "bold"),
        legend.position = "top")

print(p_traj / p_variance)

# ============================================================
# TASK 4: Phylogenetic Signal — Blomberg's K
# ============================================================
# Goal: Measure phylogenetic signal (K statistic) for traits
# simulated under BM vs OU vs random (no signal).
# ============================================================

cat("\n=== TASK 4: Phylogenetic Signal (Blomberg's K) ===\n")

tree_k <- pbtree(n = 40, scale = 1)

trait_bm_k  <- fastBM(tree_k, sig2 = 1)          # strong signal K≈1
trait_ou_k  <- fastBM(tree_k, sig2 = 1, alpha = 5) # weak signal K<1
trait_rand  <- setNames(rnorm(40), tree_k$tip.label) # no signal K≈0

k_bm   <- phylosig(tree_k, trait_bm_k,  method = "K", test = TRUE)
k_ou   <- phylosig(tree_k, trait_ou_k,  method = "K", test = TRUE)
k_rand <- phylosig(tree_k, trait_rand,  method = "K", test = TRUE)

cat(sprintf("K (BM)     = %.3f  p = %.4f\n", k_bm$K,   k_bm$P))
cat(sprintf("K (OU)     = %.3f  p = %.4f\n", k_ou$K,   k_ou$P))
cat(sprintf("K (Random) = %.3f  p = %.4f\n", k_rand$K, k_rand$P))

# Visualize: trait values vs phylogenetic distance
cophen <- cophenetic(tree_k)

get_pairs <- function(trait, label) {
  tips  <- names(trait)
  pairs <- combn(tips, 2)
  data.frame(
    phy_dist   = sapply(1:ncol(pairs), function(i)
      cophen[pairs[1,i], pairs[2,i]]),
    trait_diff = sapply(1:ncol(pairs), function(i)
      abs(trait[pairs[1,i]] - trait[pairs[2,i]])),
    model = label
  )
}

df_pairs <- rbind(
  get_pairs(trait_bm_k,  paste0("BM (K=",   round(k_bm$K,2),   ")")),
  get_pairs(trait_ou_k,  paste0("OU (K=",   round(k_ou$K,2),   ")")),
  get_pairs(trait_rand,  paste0("Random (K=",round(k_rand$K,2), ")"))
)

p_signal <- ggplot(df_pairs, aes(x = phy_dist, y = trait_diff, color = model)) +
  geom_point(alpha = 0.25, size = 1) +
  geom_smooth(method = "lm", se = TRUE, size = 1.3) +
  scale_color_manual(values = c("#2E86AB","#E84855","#2DC653")) +
  facet_wrap(~model) +
  labs(title = "TASK 4 — Phylogenetic Signal (Blomberg's K)",
       subtitle = "Steeper slope = stronger phylogenetic signal",
       x = "Phylogenetic Distance", y = "|Trait Difference|",
       color = "Model") +
  theme_minimal(base_size = 13) +
  theme(plot.title = element_text(face = "bold"),
        legend.position = "none")

print(p_signal)

