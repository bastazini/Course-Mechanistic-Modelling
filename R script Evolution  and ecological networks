# ============================================================
# TASK 6: Build a Trait-Based Bipartite Interaction Network
# ============================================================
# Goal: Create a plant-pollinator network where interactions
# are determined by trait matching (e.g., proboscis length ≈
# corolla depth). Compare networks under BM vs OU evolution.
# ============================================================

cat("\n=== TASK 6: Trait-Matching Bipartite Networks ===\n")

build_network <- function(plant_trait, poll_trait,
                          match_sd = 0.5, label = "Network") {
  np <- length(plant_trait)
  na <- length(poll_trait)
  # Interaction probability: Gaussian trait matching
  mat <- outer(plant_trait, poll_trait, function(p, a)
    exp(-((p - a)^2) / (2 * match_sd^2)))
  # Threshold to binary
  threshold <- quantile(mat, 0.65)
  mat_bin   <- (mat >= threshold) * 1
  list(prob = mat, binary = mat_bin, label = label)
}

# Simulate two guilds (plants & pollinators) under BM and OU
n_plants <- 20; n_polls <- 20
tree_p_bm <- pbtree(n = n_plants, scale = 1)
tree_a_bm <- pbtree(n = n_polls,  scale = 1)

plants_BM <- fastBM(tree_p_bm, sig2 = 0.5)
polls_BM  <- fastBM(tree_a_bm, sig2 = 0.5)

plants_OU <- fastBM(tree_p_bm, sig2 = 0.5, alpha = 3)
polls_OU  <- fastBM(tree_a_bm, sig2 = 0.5, alpha = 3)

net_BM <- build_network(plants_BM, polls_BM, label = "BM Network")
net_OU <- build_network(plants_OU, polls_OU, label = "OU Network")

# Network metrics
calc_metrics <- function(mat) {
  list(
    connectance   = mean(mat),
    links         = sum(mat),
    plant_degree  = rowSums(mat),
    poll_degree   = colSums(mat)
  )
}
m_BM <- calc_metrics(net_BM$binary)
m_OU <- calc_metrics(net_OU$binary)
cat(sprintf("BM  — Connectance: %.3f | Links: %d\n", m_BM$connectance, m_BM$links))
cat(sprintf("OU  — Connectance: %.3f | Links: %d\n", m_OU$connectance, m_OU$links))

