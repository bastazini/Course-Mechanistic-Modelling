# TASK 7: Phylogenetic Signal in Network Interactions
# ============================================================
# Goal: Test whether closely related species share similar
# interaction partners (phylogenetic signal at network level)
# using mantel tests and visualizations.
# ============================================================

cat("\n=== TASK 7: Phylogenetic Signal in Networks ===\n")

# Use plant side: phylogenetic distance vs interaction similarity
phy_dist_plants <- cophenetic(tree_p_bm)

# Interaction similarity = Jaccard similarity between rows
jaccard_sim <- function(mat) {
  n <- nrow(mat)
  sim <- matrix(0, n, n)
  for (i in 1:n) for (j in 1:n) {
    inter  <- sum(mat[i,] & mat[j,])
    union_ <- sum(mat[i,] | mat[j,])
    sim[i,j] <- if (union_ > 0) inter / union_ else 0
  }
  sim
}

int_sim_BM <- jaccard_sim(net_BM$binary)
int_sim_OU <- jaccard_sim(net_OU$binary)

# Align matrices (same species order)
sp_names   <- rownames(phy_dist_plants)
phy_dist_ord <- phy_dist_plants[sp_names, sp_names]

# Mantel test: phylogenetic distance ~ interaction dissimilarity
set.seed(123)
mantel_BM <- vegan::mantel(as.dist(phy_dist_ord),
                           as.dist(1 - int_sim_BM), permutations = 999)
mantel_OU <- vegan::mantel(as.dist(phy_dist_ord),
                           as.dist(1 - int_sim_OU), permutations = 999)

cat(sprintf("Mantel r (BM): %.3f  p = %.4f\n", mantel_BM$statistic, mantel_BM$signif))
cat(sprintf("Mantel r (OU): %.3f  p = %.4f\n", mantel_OU$statistic, mantel_OU$signif))

# Build data frame for scatter: phy_dist vs interaction dissimilarity
build_mantel_df <- function(phy, int_sim, label) {
  phy_v  <- as.vector(as.dist(phy))
  sim_v  <- as.vector(as.dist(int_sim))
  data.frame(phy_dist = phy_v, int_dissim = 1 - sim_v, model = label)
}

df_mantel <- rbind(
  build_mantel_df(phy_dist_ord, int_sim_BM,
                  paste0("BM (r=",  round(mantel_BM$statistic,3),
                         ", p=", round(mantel_BM$signif,3), ")")),
  build_mantel_df(phy_dist_ord, int_sim_OU,
                  paste0("OU (r=",  round(mantel_OU$statistic,3),
                         ", p=", round(mantel_OU$signif,3), ")"))
)

p_mantel <- ggplot(df_mantel, aes(x = phy_dist, y = int_dissim, color = model)) +
  geom_point(alpha = 0.3, size = 1.5) +
  geom_smooth(method = "lm", se = TRUE, size = 1.3) +
  scale_color_manual(values = c("#2E86AB","#E84855")) +
  facet_wrap(~model) +
  labs(title = "TASK 7 — Phylogenetic Signal in Interaction Networks",
       subtitle = "Mantel test: phylogenetic distance vs. interaction dissimilarity",
       x = "Phylogenetic Distance", y = "Interaction Dissimilarity (1 - Jaccard)",
       color = "Model") +
  theme_minimal(base_size = 13) +
  theme(plot.title = element_text(face = "bold"),
        legend.position = "none")

# Heatmap: interaction similarity matrix ordered by phylogeny
order_by_phylo <- function(tree) {
  # Use the order species appear in tree plot
  plot(tree, plot = FALSE)
  # Simple: use tip order
  tree$tip.label
}
tip_order <- order_by_phylo(tree_p_bm)

sim_df_BM <- as.data.frame(int_sim_BM)
sim_df_BM$sp1 <- factor(rownames(sim_df_BM), levels = tip_order)
sim_melt_BM <- reshape(sim_df_BM,
                       varying   = 1:n_plants,
                       v.names   = "similarity",
                       timevar   = "sp2_idx",
                       times     = colnames(sim_df_BM)[1:n_plants],
                       direction = "long")
sim_melt_BM$sp2 <- factor(sim_melt_BM$sp2_idx, levels = tip_order)

p_heatmap <- ggplot(sim_melt_BM, aes(x = sp2, y = sp1, fill = similarity)) +
  geom_tile() +
  scale_fill_gradient2(low = "#F0F0F0", mid = "#4CC9F0", high = "#2E86AB",
                       midpoint = 0.4) +
  labs(title = "Plant Interaction Similarity (BM network)",
       subtitle = "Species ordered by phylogeny — diagonal blocks = phylogenetic signal",
       x = "Plant Species", y = "Plant Species",
       fill = "Jaccard\nSimilarity") +
  theme_minimal(base_size = 11) +
  theme(axis.text = element_text(size = 7),
        plot.title = element_text(face = "bold"))

print(p_mantel / p_heatmap + plot_layout(heights = c(2,3)))

