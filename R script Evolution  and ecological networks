# ============================================================

cat("\n=== TASK 5: Community Assembly via Environmental Filtering ===\n")

# Regional pool: 200 species, traits evolved under BM
pool_tree  <- pbtree(n = 200, scale = 1)
pool_trait <- fastBM(pool_tree, sig2 = 0.8)

# Three local environments with different optima
envs <- list(cold = -2, temperate = 0, hot = 2)

# Filter: probability of inclusion ~ Gaussian around optimum
filter_community <- function(traits, optimum, breadth = 0.8) {
  probs <- exp(-((traits - optimum)^2) / (2 * breadth^2))
  selected <- rbinom(length(traits), 1, probs / max(probs))
  traits[selected == 1]
}

communities <- lapply(names(envs), function(e)
  data.frame(trait = filter_community(pool_trait, envs[[e]]),
             community = e))

df_assembly <- do.call(rbind, communities)
df_pool     <- data.frame(trait = pool_trait, community = "Regional Pool")
df_all      <- rbind(df_pool, df_assembly)
df_all$community <- factor(df_all$community,
                           levels = c("Regional Pool","cold","temperate","hot"))

colors_env <- c("Regional Pool" = "grey60",
                "cold"          = "#4CC9F0",
                "temperate"     = "#2DC653",
                "hot"           = "#F4A261")

p_assembly <- ggplot(df_all, aes(x = trait, fill = community,
                                 color = community)) +
  geom_density(alpha = 0.45, size = 1) +
  geom_vline(xintercept = c(-2, 0, 2),
             linetype = "dashed", color = c("#4CC9F0","#2DC653","#F4A261"),
             size = 0.9) +
  scale_fill_manual(values  = colors_env) +
  scale_color_manual(values = colors_env) +
  labs(title = "TASK 5 — Community Assembly: Environmental Filtering",
       subtitle = "Dashed lines = environmental optima; filtering shifts community trait distributions",
